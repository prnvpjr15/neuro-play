{
  "name": "autism-support-project-root",
  "version": "1.0.0",
  "description": "Root manager for Autism Support Platform",
  "scripts": {
    "start": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "start:backend": "cd autism-backend && npm start",
    "start:frontend": "cd autism-dashboard && npm start",
    "install:all": "npm install && cd autism-backend && npm install && cd autism-dashboard && npm install"
  },
  "keywords": [
    "autism",
    "support"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "@tensorflow/tfjs": "^4.22.0",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  }
}
